# Firebase project config (Project settings → General → Your apps → SDK setup and configuration).
# These are client-side config values, not secrets — Firebase access is controlled by
# Firestore/Auth security rules, not by hiding these. Copy this file to `.env` and fill in
# your project's values to enable real Firebase Authentication + Firestore.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
